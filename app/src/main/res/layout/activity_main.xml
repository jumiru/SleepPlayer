<?xml version="1.0" encoding="utf-8"?>
<!-- Root FrameLayout erlaubt das vollflächige Overlay über dem gesamten Inhalt -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    tools:context=".MainActivity">

    <!-- ===== Haupt-Inhalt ===== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp">

        <!-- ===== Titelzeile mit Settings-Button ===== -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="22sp"
            android:textColor="@color/purple_200"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnSettings" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/settings"
            android:scaleType="fitCenter"
            app:layout_constraintTop_toTopOf="@id/tvAppTitle"
            app:layout_constraintBottom_toBottomOf="@id/tvAppTitle"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ===== Now Playing Card (Album Art + Controls nebeneinander) ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNowPlaying"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <!-- Album Art – anklickbar für Vollbild -->
                <ImageView
                    android:id="@+id/ivAlbumArt"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_album_placeholder"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/album_art_desc"
                    android:background="@drawable/album_art_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless" />

                <!-- Rechte Seite: Track-Info + Controls -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <!-- Track name -->
                    <TextView
                        android:id="@+id/tvTrackName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_track"
                        android:textSize="15sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:ellipsize="marquee"
                        android:singleLine="true"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                    <!-- Track artist -->
                    <TextView
                        android:id="@+id/tvTrackArtist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#B0FFFFFF"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:singleLine="true"
                        tools:text="Künstler" />

                    <!-- Play + Skip + Random Switch in einer Zeile -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <ImageButton
                            android:id="@+id/btnPlayPause"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_play"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/play"
                            android:scaleType="fitCenter" />

                        <ImageButton
                            android:id="@+id/btnSkip"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_skip_next"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/next_track"
                            android:scaleType="fitCenter"
                            android:layout_marginStart="4dp" />

                        <!-- Spacer -->
                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <!-- Random Switch -->
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchRandom"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:contentDescription="@string/random_mode" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== Lautstärke Card ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardVolume"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/cardNowPlaying"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvVolumeLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/volume"
                        android:textSize="13sp"
                        android:textColor="@color/teal_200" />

                    <TextView
                        android:id="@+id/tvVolumePercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#80FFFFFF"
                        tools:text="15%" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekVolume"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="200"
                    android:progress="30"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== Timer Card (kompakt, alles in einer Zeile) ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTimer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/cardVolume"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sleep_timer"
                    android:textSize="13sp"
                    android:textColor="@color/teal_200"
                    android:layout_marginEnd="8dp" />

                <Spinner
                    android:id="@+id/spinnerTimer"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvTimerRemaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/timer_off"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:layout_marginStart="10dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== Track-Anzahl ===== -->
        <TextView
            android:id="@+id/tvTrackCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="12sp"
            android:textColor="#80FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/cardTimer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="42 Titel gefunden" />

        <!-- ===== Track-Liste (füllt restlichen Platz) ===== -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTracks"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvTrackCount"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ===== Vollbild-Overlay für Album Art (über allem, initial unsichtbar) ===== -->
    <FrameLayout
        android:id="@+id/overlayAlbumArt"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DD000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/ivAlbumArtFull"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:padding="32dp"
            android:contentDescription="@string/album_art_desc" />

        <!-- Schließen-Hinweis -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="32dp"
            android:text="Antippen zum Schließen"
            android:textColor="#80FFFFFF"
            android:textSize="13sp" />

    </FrameLayout>

</FrameLayout>
